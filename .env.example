# Instagram – target profile (must be public, or use session login)
IG_USERNAME=your_instagram_username

# Instagram – optional login credentials (reduces rate-limit risk)
# Leave empty to scrape anonymously (public profiles only)
IG_SESSION_USER=
IG_SESSION_PASS=

# WordPress REST API
WP_URL=https://your-wordpress-site.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_wp_application_password

# Scheduler – minutes between syncs (default: 1440 = once per day)
SYNC_INTERVAL_MINUTES=1440
